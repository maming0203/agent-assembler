{
  "name": "{{ tool_name | default(skill_name | replace(' ', '_') | lower) }}",
  "version": "{{ version | default('1.0.0') }}",
  "description": "{{ recipe_name }} — Auto-generated MCP tool",
  "recipe": "{{ recipe_name }}",
  "tools": [
    {
      "name": "{{ recipe_name | replace(' ', '-') | lower }}",
      "description": "{{ recipe_name }} 配方执行工具",
      "input_schema": {
        "type": "object",
        "required": {{ required_params | default(["query"]) | tojson }},
        "properties": {
          {% for param in input_schema %}
          "{{ param.name }}": {
            "type": "{{ 'string' if param.type == 'string' else 'number' if param.type in ['number', 'integer', 'float'] else 'object' }}",
            "description": "{{ param.description }}"
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          {% for field in output_schema %}
          "{{ field.name }}": {
            "type": "{{ 'string' if field.type == 'string' else 'number' if field.type in ['number', 'integer', 'float'] else 'object' }}",
            "description": "{{ field.description }}"
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        }
      }
    }
  ],
  "execution": {
    "command": ["python3", "{{ script_path | default('recipe_script.py') }}", "--json"],
    "timeout": {{ timeout | default(60) }},
    "retry": {{ retry_count | default(0) }}
  },
  "trigger_keywords": {{ trigger_keywords | tojson }},
  "created": "{{ created_date | default('2026-06-10') }}"
}
