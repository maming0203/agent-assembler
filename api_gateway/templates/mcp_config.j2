{
  "name": "{{ tool_name | default(skill_name | replace(' ', '_') | lower) }}",
  "description": "{{ recipe_name }} — Auto-generated MCP tool",
  "version": "{{ version | default('1.0.0') }}",
  "recipe": "{{ recipe_name }}",
  "input_schema": {
    "type": "object",
    "properties": {
      {% for param in input_schema %}
      "{{ param.name }}": {
        "type": "{{ param.type }}",
        "description": "{{ param.description }}"{% if param.required %},
        "required": true{% endif %}{% if param.default is defined %},
        "default": {{ param.default | tojson }}{% endif %}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    },
    "required": {{ required_params | default([]) | tojson }}
  },
  "output_schema": {
    "type": "object",
    "properties": {
      {% for field in output_schema %}
      "{{ field.name }}": {
        "type": "{{ field.type }}",
        "description": "{{ field.description }}"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    }
  },
  "execution": {
    "command": ["python3", "{{ script_path | default('recipe_script.py') }}", "--json"],
    "timeout": {{ timeout | default(60) }},
    "retry": {{ retry_count | default(0) }}
  },
  "trigger_keywords": {{ trigger_keywords | tojson }},
  "created": "{{ created_date | default('2026-06-10') }}"
}
